# Web Search MCP Server Configuration
# Copy this file to .env and fill in your API keys

# Tavily Search API (https://tavily.com/)
# When configured, Tavily becomes the default engine unless DEFAULT_SEARCH_ENGINE overrides it.
TAVILY_API_KEY=
# TAVILY_API_URL=https://api.tavily.com/search
# TAVILY_TIMEOUT_MS=30000

# Bing Search API (https://www.microsoft.com/en-us/bing/apis/bing-web-search-api)
BING_API_KEY=

# Google Custom Search API (https://developers.google.com/custom-search/v1/overview)
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Brave Search API (https://brave.com/search/api/)
BRAVE_API_KEY=

# SerpApi (https://serpapi.com/)
SERPAPI_API_KEY=

# SearXNG Instance URL (self-hosted)
# When set without Tavily, SearXNG is used by default unless DEFAULT_SEARCH_ENGINE overrides it.
SEARXNG_URL=

# Optional: automatically start a local SearXNG Docker container when SearXNG is selected.
# Requires Docker to be installed and running. If SEARXNG_URL is unset, the MCP server uses http://127.0.0.1:8888.
SEARXNG_AUTO_START=false
# SEARXNG_LANGUAGE=zh-CN
# SEARXNG_ENGINES=
# SEARXNG_SAFESEARCH=0
# SEARXNG_PAGE_COUNT=3
# SEARXNG_DOCKER_PORT=8888
# SEARXNG_DOCKER_CONTAINER_NAME=bigopen-llm-search-searxng
# SEARXNG_DOCKER_IMAGE=docker.io/searxng/searxng:latest
# SEARXNG_DOCKER_CONFIG_DIR=~/.bigopen-llm-search/searxng/config
# SEARXNG_DOCKER_DATA_DIR=~/.bigopen-llm-search/searxng/data
# SEARXNG_DOCKER_START_TIMEOUT_MS=30000

# Default search engine (tavily, searxng, duckduckgo, bing, google, brave, serpapi)
# If unset: Tavily when TAVILY_API_KEY is set, otherwise SearXNG when configured, otherwise DuckDuckGo.
# DEFAULT_SEARCH_ENGINE=

# Optional OpenAI-compatible LLM for include_answer generation.
# If LLM_API_KEY or LLM_MODEL is missing, answers fall back to extractive summaries from sources.
LLM_API_KEY=
LLM_MODEL=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MAX_TOKENS=900
# LLM_TEMPERATURE=0.2

# Mature search pipeline
# SEARCH_QUERY_REWRITE=auto
# SEARCH_QUERY_REWRITE_MODEL=
# SEARCH_MAX_RECALL_QUERIES=4
# SEARCH_RRF_K=60
# SEARCH_CANDIDATE_LIMIT=80
# SEARCH_ENABLE_CONTENT_RERANK=true
# SEARCH_RERANK_TOP_N=40
# SEARCH_CHUNK_SIZE=1000
# SEARCH_CHUNK_OVERLAP=150
# SEARCH_RERANK_RRF_WEIGHT=0.25
# SEARCH_RERANK_LEXICAL_WEIGHT=0.30
# SEARCH_RERANK_VECTOR_WEIGHT=0.35
# SEARCH_RERANK_FRESHNESS_WEIGHT=0.10

# Optional OpenAI-compatible embeddings for chunk reranking.
# If EMBEDDING_MODEL is missing, vector reranking is skipped and lexical reranking is used.
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_BATCH_SIZE=32
