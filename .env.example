# Web Search MCP Server Configuration
# Copy this file to .env and fill in your API keys

# Bing Search API (https://www.microsoft.com/en-us/bing/apis/bing-web-search-api)
BING_API_KEY=

# Google Custom Search API (https://developers.google.com/custom-search/v1/overview)
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Brave Search API (https://brave.com/search/api/)
BRAVE_API_KEY=

# SerpApi (https://serpapi.com/)
SERPAPI_API_KEY=

# SearXNG Instance URL (self-hosted)
SEARXNG_URL=

# Default search engine (duckduckgo, bing, google, brave, serpapi, searxng)
# DEFAULT_SEARCH_ENGINE=duckduckgo

# Optional OpenAI-compatible LLM for include_answer/web_research answer generation.
# If LLM_API_KEY or LLM_MODEL is missing, answers fall back to extractive summaries from sources.
LLM_API_KEY=
LLM_MODEL=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MAX_TOKENS=900
# LLM_TEMPERATURE=0.2
