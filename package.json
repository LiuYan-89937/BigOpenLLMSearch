{
  "name": "bigopen-llm-search",
  "version": "1.0.0",
  "description": "BigOpenLLMSearch - MCP server for web search, extraction, crawling, and research for LLM",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bigopen-llm-search": "dist/index.js"
  },
  "files": [
    "dist",
    "config",
    "README.md",
    "操作指南.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "mcp",
    "web-search",
    "llm",
    "ai",
    "search-api",
    "tavily-alternative"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LiuYan-89937/BigOpenLLMSearch.git"
  },
  "bugs": {
    "url": "https://github.com/LiuYan-89937/BigOpenLLMSearch/issues"
  },
  "homepage": "https://github.com/LiuYan-89937/BigOpenLLMSearch#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "turndown": "^7.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
